# Provider API Configuration

# dev.to
DEVTO_API_KEY=your_dev_to_api_key_here
# Qiita
QIITA_ACCESS_TOKEN=your_qiita_access_token_here

# Provider Selection
DEFAULT_PROVIDER=devto
PROVIDERS=devto,qiita

# Hugo Site Configuration
HUGO_BASE_URL=https://yoursite.com
CONTENT_DIR=content/

# Debug Configuration
DEBUG_LEVEL=2

# Sync Behavior
FORCE_SYNC_ALL=false
AUTO_DELETE=false